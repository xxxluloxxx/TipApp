{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  // src/sw.ts corre en el contexto de un Service Worker (WebWorker), no en el
  // DOM: usa `self`/`ServiceWorkerGlobalScope`/`self.__WB_MANIFEST`, ajenos a
  // la lib DOM que usa el resto de la app. vite-plugin-pwa lo compila aparte
  // con esbuild (estrategia injectManifest), así que se excluye del
  // type-check de `vue-tsc --build` para no mezclar las libs WebWorker/DOM.
  "exclude": ["src/**/__tests__/*", "src/sw.ts"],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
