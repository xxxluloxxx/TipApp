# Supabase (frontend, Vite). Solo la anon key es pública / segura de exponer.
# Nunca coloques aquí la service_role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (Partidos en vivo). Clave pública VAPID — es pública / segura de
# exponer en el cliente. La clave privada VAPID nunca va acá: vive en el
# backend (Edge Functions de Supabase).
VITE_VAPID_PUBLIC_KEY=
